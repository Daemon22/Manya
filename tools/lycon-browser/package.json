{
  "name": "@manya/lycon",
  "version": "1.0.0",
  "description": "Manya Lycon — Privacy-first web browser integrated with the Manya ecosystem. Lycon's shields, tabs, bookmarks, history, and downloads are wired into Manya Unify's event bus and identity federation.",
  "type": "module",
  "main": "main.js",
  "manya": {
    "main": "manya/index.js",
    "types": "manya/types.d.ts"
  },
  "scripts": {
    "test": "node --test manya/test/index.test.js manya/test/deep-integration.test.js",
    "start": "electron .",
    "dev": "electron . --dev",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build": "electron-builder -mwl"
  },
  "dependencies": {
    "@manya/toolkit": "*",
    "@manya/unify": "*",
    "@cliqz/adblocker-electron": "^1.27.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.manya.lycon",
    "productName": "Lycon",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "build/**/*",
      "manya/**/*.js"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.utilities",
      "icon": "build/icon.png"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.png"
    }
  },
  "author": "Manya + Lycon Project",
  "license": "MPL-2.0"
}
