    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test"
  },
  "keywords": [
    "manya",
    "memory",
    "episodic",
    "semantic",
    "procedural",
    "working-memory"
  ],
  "dependencies": {
    "@manya/vault": "^1.0.0",
    "@manya/stamp": "^1.0.0",
    "@manya/unify": "^1.0.0"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Daemon22/Manya.git",
    "directory": "packages/memory"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "require": "src/index.js",
      "default": "src/index.js"
    },
    "./package.json": "./package.json"
