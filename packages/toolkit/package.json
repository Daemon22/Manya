{
  "name": "@manya/toolkit",
  "version": "0.2.0",
  "description": "Shared manifests, boundaries, and synchronization contracts for Manya tools.",
  "author": "Uviwe Menyiwe (Azura Daemon)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "src/index.js",
  "types": "./src/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test"
  },
  "keywords": [
    "manya",
    "toolkit",
    "manifest",
    "orchestration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Daemon22/Manya.git",
    "directory": "packages/toolkit"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "require": "src/index.js",
      "default": "src/index.js"
    },
    "./package.json": "./package.json"
  }
}
