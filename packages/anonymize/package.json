{
  "name": "@manya/anonymize",
  "version": "1.0.0",
  "description": "Dataset redaction and FAIR-compliance certification for publishing research data \u2014 composed from lens and research-academic.",
  "author": "Uviwe Menyiwe (Azura Daemon)",
  "license": "MIT",
  "type": "module",
  "main": "src/index.js",
  "types": "./src/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test"
  },
  "keywords": [
    "manya",
    "anonymize",
    "redaction",
    "fair",
    "research-data",
    "pii"
  ],
  "dependencies": {
    "@manya/lens": "^1.0.0",
    "@manya/research-academic": "^1.0.0"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Daemon22/Manya.git",
    "directory": "packages/anonymize"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "require": "src/index.js",
      "default": "src/index.js"
    },
    "./package.json": "./package.json"
  }
}
