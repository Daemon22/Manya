{
  "name": "@manya/weave",
  "version": "1.0.0",
  "description": "Interactive visualization substrate for the MANYA Intelligence OS \u2014 dependency graphs, knowledge graphs, event flows, layouts, filtering, search, export, live topology tracking, and pan/zoom exploration.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-package.js weave",
    "test": "node --test test/smoke.test.js",
    "clean": "rm -rf dist build node_modules",
    "build:types": "node ../../scripts/build-types.js weave",
    "build:bundle": "node ../../scripts/build-package.js weave --no-types && node ../../scripts/build-types.js weave"
  },
  "keywords": [
    "manya",
    "weave",
    "graph",
    "visualization",
    "layout",
    "force-directed",
    "topology",
    "dependency-graph",
    "knowledge-graph",
    "svg",
    "graphviz",
    "mermaid"
  ],
  "author": "Uviwe Menyiwe (Azura Daemon)",
  "license": "Apache-2.0",
  "dependencies": {},
  "devDependencies": {},
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "dist/index.d.ts",
      "import": "dist/index.mjs",
      "require": "dist/index.js",
      "default": "dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Daemon22/Manya.git",
    "directory": "packages/weave"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
