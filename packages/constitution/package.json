{
  "name": "@manya/constitution",
  "version": "1.0.0",
  "description": "Governance substrate for the MANYA Intelligence OS \u2014 ethical rules, operational policies, permission models, decision hierarchies, emergency procedures, safety rules, conflict resolution, runtime enforcement, and versioned governance documents.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-package.js constitution",
    "test": "node --test test/smoke.test.js",
    "clean": "rm -rf dist build node_modules",
    "build:types": "node ../../scripts/build-types.js constitution",
    "build:bundle": "node ../../scripts/build-package.js constitution --no-types && node ../../scripts/build-types.js constitution"
  },
  "keywords": [
    "manya",
    "constitution",
    "governance",
    "ethics",
    "policy",
    "permissions",
    "rbac",
    "hierarchy",
    "emergency",
    "safety",
    "conflict-resolution",
    "enforcement",
    "rules-engine"
  ],
  "author": "Uviwe Menyiwe (Azura Daemon)",
  "license": "Apache-2.0",
  "dependencies": {},
  "devDependencies": {},
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "dist/index.d.ts",
      "import": "dist/index.mjs",
      "require": "dist/index.js",
      "default": "dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Daemon22/Manya.git",
    "directory": "packages/constitution"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
