{
  "name": "@manya/cortex",
  "version": "1.0.0",
  "description": "A reasoning fabric that routes tasks to the tools that already own them, gates dispatch through access control, and chains every decision into an auditable trail \u2014 composed from memory, unify, shield, and stamp.",
  "author": "Uviwe Menyiwe (Azura Daemon)",
  "license": "MIT",
  "type": "module",
  "main": "src/index.js",
  "types": "./src/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test"
  },
  "keywords": [
    "manya",
    "cortex",
    "reasoning",
    "orchestration",
    "routing"
  ],
  "dependencies": {
    "@manya/memory": "^1.0.0",
    "@manya/unify": "^1.0.0",
    "@manya/shield": "^1.0.0",
    "@manya/stamp": "^1.0.0"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Daemon22/Manya.git",
    "directory": "packages/cortex"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "require": "src/index.js",
      "default": "src/index.js"
    },
    "./package.json": "./package.json"
  }
}
