{
  "name": "@manya/customs-shield",
  "version": "1.0.0",
  "description": "Compliance and supply-chain intelligence \u2014 customs validation, HS code verification, sanctions screening, import/export compliance, cargo risk assessment, and shipment risk scoring for the MANYA Intelligence OS.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-package.js customs-shield",
    "test": "node --test test/smoke.test.js",
    "bench": "node benchmarks/shield.bench.js",
    "clean": "rm -rf dist build node_modules",
    "build:types": "node ../../scripts/build-types.js customs-shield",
    "build:bundle": "node ../../scripts/build-package.js customs-shield --no-types && node ../../scripts/build-types.js customs-shield"
  },
  "keywords": [
    "manya",
    "customs",
    "compliance",
    "hs-code",
    "sanctions",
    "supply-chain",
    "trade",
    "risk",
    "import-export"
  ],
  "author": "Uviwe Menyiwe (Azura Daemon)",
  "license": "Apache-2.0",
  "dependencies": {},
  "devDependencies": {},
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "dist/index.d.ts",
      "import": "dist/index.mjs",
      "require": "dist/index.js",
      "default": "dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Daemon22/Manya.git",
    "directory": "packages/customs-shield"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
