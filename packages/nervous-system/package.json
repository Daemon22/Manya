{
  "name": "@manya/nervous-system",
  "version": "1.0.0",
  "description": "Universal event infrastructure \u2014 publish/subscribe event fabric, filtering, priority routing, ring-buffer recording, bounded/unbounded queues, performance metrics, and pluggable event sources for the MANYA Intelligence OS.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-package.js nervous-system",
    "test": "node --test test/smoke.test.js",
    "clean": "rm -rf dist build node_modules",
    "build:types": "node ../../scripts/build-types.js nervous-system",
    "build:bundle": "node ../../scripts/build-package.js nervous-system --no-types && node ../../scripts/build-types.js nervous-system"
  },
  "keywords": [
    "manya",
    "events",
    "event-fabric",
    "pubsub",
    "router",
    "realtime",
    "observability",
    "sources",
    "nervous-system"
  ],
  "author": "Uviwe Menyiwe (Azura Daemon)",
  "license": "Apache-2.0",
  "dependencies": {},
  "devDependencies": {},
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "dist/index.d.ts",
      "import": "dist/index.mjs",
      "require": "dist/index.js",
      "default": "dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Daemon22/Manya.git",
    "directory": "packages/nervous-system"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
