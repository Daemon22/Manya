{
  "name": "@manya/contracts",
  "version": "1.0.0",
  "description": "Universal contract and schema validation for the MANYA Intelligence OS \u2014 interface schemas, manifests, semver compatibility, API contracts, schema sync, boundary enforcement, and validation reports.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-package.js contracts",
    "test": "node --test test/smoke.test.js",
    "clean": "rm -rf dist build node_modules",
    "build:types": "node ../../scripts/build-types.js contracts",
    "build:bundle": "node ../../scripts/build-package.js contracts --no-types && node ../../scripts/build-types.js contracts"
  },
  "keywords": [
    "manya",
    "contracts",
    "schema",
    "validation",
    "manifest",
    "semver",
    "compatibility",
    "api",
    "boundaries",
    "interface"
  ],
  "author": "Uviwe Menyiwe (Azura Daemon)",
  "license": "Apache-2.0",
  "dependencies": {},
  "devDependencies": {},
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "dist/index.d.ts",
      "import": "dist/index.mjs",
      "require": "dist/index.js",
      "default": "dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Daemon22/Manya.git",
    "directory": "packages/contracts"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
