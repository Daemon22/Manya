{
  "name": "@manya/ledger",
  "version": "1.0.0",
  "description": "Federated audit ledger: every event that crosses the bus gets tamper-evidently chained \u2014 composed from stamp and unify.",
  "author": "Uviwe Menyiwe (Azura Daemon)",
  "license": "MIT",
  "type": "module",
  "main": "src/index.js",
  "types": "./src/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test"
  },
  "keywords": [
    "manya",
    "ledger",
    "audit",
    "provenance",
    "event-bus"
  ],
  "dependencies": {
    "@manya/stamp": "^1.0.0",
    "@manya/unify": "^1.0.0"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Daemon22/Manya.git",
    "directory": "packages/ledger"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "require": "src/index.js",
      "default": "src/index.js"
    },
    "./package.json": "./package.json"
  }
